# VeriContent AI - Environment configuration
# Copy this file to .env.local and fill in real values to enable live backend.
# The app runs fully in DEMO MODE (rich mock data) when these are left blank.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM (server-side content generation) ---
# Set ONE of the following. Anthropic wins if both are set.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
GEMINI_MODEL=gemini-2.0-flash